# keyflow.toml — KeyFlow 配置示例
# 完整路径：~/.config/keyflow/keyflow.toml

# ==================== 全局设置 ====================

[settings]
# 剪贴板清理延迟（秒）。输入完成后等待指定时间后清空剪贴板。
# 0 = 不清理。binding 级别的 clipboard_clear_after_secs 会覆盖此值。
clipboard_clear_after_secs = 5

# Bitwarden 会话密钥（可选）。
# 通过 `keyflow unlock` 命令自动设置，或手动从 `bw unlock --raw` 获取。
# 设置后 daemon 启动时自动使用，无需配置 BW_SESSION 环境变量。
# bw_session = "0.xxxxxxxx..."

# 加密密钥（可选）。
# 用于加密 static 类型的 content 字段。通过 `keyflow encrypt` 命令加密内容。
# 设置后 daemon 启动时自动使用，无需额外配置。
# encryption_key = "your-secret-key"

# ==================== 热键绑定 ====================

# 示例 1：Bitwarden 密码 + 逐字符输入
# 适用于禁粘贴场景。cli_path 可选，未配置时自动搜索常见路径。
# cache_secs 缓存密码，避免每次触发都调用 bw CLI（Node.js 启动开销大）。
[[bindings]]
name = "Bitwarden 密码"
hotkey = "F7"
provider = "bitwarden"
item_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# cli_path = "/usr/local/bin/bw"  # 可选：指定 bw CLI 路径
cache_secs = 300  # 缓存 5 分钟，首次触发后后续直接使用缓存
# input_mode 默认为 auto（等同 type）

# 示例 2：剪贴板 + 逐字符输入
# 适用于禁粘贴字段
[[bindings]]
name = "密码框输入"
hotkey = "F8"
provider = "clipboard"
input_mode = "type"

# 示例 3：剪贴板 + 粘贴模式
# 适用于正常编辑器，保留格式
[[bindings]]
name = "编辑器粘贴"
hotkey = "F9"
provider = "clipboard"
input_mode = "paste"
clipboard_clear_after_secs = 0  # 不清理剪贴板

# 示例 4：组合键
[[bindings]]
name = "安全输入"
hotkey = "Ctrl+Shift+F7"
provider = "clipboard"
input_mode = "type"
clipboard_clear_after_secs = 3

# 示例 5：静态文本（明文）
# 直接在配置文件中定义要输入的内容
[[bindings]]
name = "邮箱地址"
hotkey = "F10"
provider = "static"
content = "user@example.com"

# 示例 6：静态文本（加密）
# 使用 `keyflow encrypt "your-secret"` 加密内容
# 需要在 [settings] 中配置 encryption_key
[[bindings]]
name = "API Key"
hotkey = "F11"
provider = "static"
content = "enc:v1:aGVsbG8gd29ybGQ..."  # 替换为实际加密内容
encrypted = true

# ==================== 附录 ====================
#
# 数据源（provider）：
#   clipboard  — 从系统剪贴板读取
#   bitwarden  — 从 Bitwarden vault 获取密码
#   static     — 配置文件中定义的静态文本
#
# 静态文本加密：
#   1. 在 [settings] 中设置 encryption_key
#   2. 运行 `keyflow encrypt "要加密的内容"` 获取加密字符串
#   3. 在 binding 中设置 content = "enc:v1:..." 和 encrypted = true
#
# 热键格式：
#   单键：       F7, F8, F9, F10, ...
#   组合键：     Ctrl+F7, Shift+F9, Alt+A, Super+V
#   多修饰键：   Ctrl+Shift+F7, Ctrl+Alt+A
#
# 输入模式（input_mode）：
#   auto   — 默认，等同于 type
#   type   — 逐字符键盘输入，绕过禁粘贴字段
#   paste  — Ctrl+V 剪贴板粘贴，保留格式
#
# 剪贴板清理（clipboard_clear_after_secs）：
#   > 0 — 输入完成后 N 秒清空剪贴板（仅当内容未变化时）
#   = 0 — 不清空剪贴板
#   优先级：binding 级别 > 全局 settings 级别
#
# CLI 路径（cli_path）：
#   可选。未配置时自动搜索常见安装路径（/usr/bin/bw, /usr/local/bin/bw 等）。
#   配置后以配置值为准。两者都找不到时报告错误。
#
# 密码缓存（cache_secs）：
#   > 0 — 缓存密码 N 秒，避免重复调用 CLI（主要针对 bitwarden）
#   = 0 或未配置 — 不缓存，每次触发都调用 CLI
#   缓存仅存储在内存中，进程退出自动清除
